{
  "name": "@chatcore/server",
  "version": "1.0.0",
  "description": "Lightweight realtime chat core framework with pluggable auth and persistence.",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./client": {
      "import": "./dist/client.js",
      "require": "./dist/client.js",
      "types": "./dist/client.d.ts"
    },
    "./events": {
      "import": "./dist/events.js",
      "require": "./dist/events.js",
      "types": "./dist/events.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts,.js",
    "start": "node dist/example-server.js"
  },
  "dependencies": {
    "mongoose": "^9.5.0",
    "uuid": "^9.0.1",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/uuid": "^9.0.7",
    "@types/ws": "^8.5.10",
    "eslint": "^8.55.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "keywords": [
    "chat",
    "websocket",
    "realtime",
    "framework"
  ],
  "license": "MIT",
  "files": [
    "dist",
    "src",
    "README.md",
    "USAGE.md"
  ]
}
